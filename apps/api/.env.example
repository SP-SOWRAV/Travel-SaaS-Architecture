# Copy this file to .env and fill in real values before running the API.
# See ENVIRONMENT_VARIABLES.md (repo root) for the full reference (required vs
# optional, defaults, and how each value is used).

# Required. PostgreSQL connection string.
DATABASE_URL=postgresql://ota_user:ota_password@localhost:5432/ota_saas_dev

# Required. Secret used to sign JWTs — must be at least 32 characters. Generate a real
# one with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-string-at-least-32-characters-long

# Optional. Defaults to 1h if unset.
JWT_EXPIRES_IN=1h

# Optional. Comma-separated list of allowed frontend origins (never '*'). Defaults to
# http://localhost:3000 if unset.
CORS_ORIGIN=http://localhost:3000

# Optional. Defaults to 3001 if unset.
PORT=3001
