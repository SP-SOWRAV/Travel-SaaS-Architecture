generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AgencyStatus {
  trial
  active
  suspended

  @@map("agency_status")
}

model Agency {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @db.VarChar(255)
  status    AgencyStatus @default(trial)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz

  users     User[]
  settings  Settings?
  branches  Branch[]
  customers Customer[]
  bookings  Booking[]

  @@map("agencies")
}

enum UserRole {
  platform_admin
  agency_admin
  branch_manager
  agent

  @@map("user_role")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String?   @map("tenant_id") @db.Uuid
  branchId     String?   @map("branch_id") @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  fullName     String    @map("full_name") @db.VarChar(255)
  role         UserRole  @default(agent)
  phone        String?   @db.VarChar(30)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  agency Agency? @relation(fields: [tenantId], references: [id])
  branch Branch?  @relation(fields: [branchId], references: [id])
  bookingsAsAgent Booking[]

  @@index([tenantId])
  @@index([tenantId, role])
  @@map("users")
}

enum SettingsTheme {
  light
  dark
  system

  @@map("settings_theme")
}

model Settings {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @unique @map("tenant_id") @db.Uuid
  legalName     String?       @map("legal_name") @db.VarChar(255)
  logoUrl       String?       @map("logo_url") @db.VarChar(500)
  theme         SettingsTheme @default(system)
  currencyCode  String        @default("USD") @map("currency_code") @db.Char(3)
  timezone      String        @default("UTC") @db.VarChar(64)
  invoicePrefix String        @default("INV-") @map("invoice_prefix") @db.VarChar(10)
  ticketPrefix  String        @default("TKT-") @map("ticket_prefix") @db.VarChar(10)
  contactEmail  String?       @map("contact_email") @db.VarChar(255)
  contactPhone  String?       @map("contact_phone") @db.VarChar(30)
  addressLine1  String?       @map("address_line1") @db.VarChar(255)
  addressLine2  String?       @map("address_line2") @db.VarChar(255)
  cityId        String?       @map("city_id") @db.Uuid
  countryId     String?       @map("country_id") @db.Uuid
  postalCode    String?       @map("postal_code") @db.VarChar(20)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  agency Agency @relation(fields: [tenantId], references: [id])

  @@map("settings")
}

model Branch {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  name         String    @db.VarChar(255)
  code         String    @db.VarChar(20)
  addressLine1 String?   @map("address_line1") @db.VarChar(255)
  cityId       String?   @map("city_id") @db.Uuid
  countryId    String?   @map("country_id") @db.Uuid
  phone        String?   @db.VarChar(30)
  email        String?   @db.VarChar(255)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  agency   Agency    @relation(fields: [tenantId], references: [id])
  users    User[]
  bookings Booking[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

model Customer {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  fullName             String    @map("full_name") @db.VarChar(255)
  email                String?   @db.VarChar(255)
  phone                String?   @db.VarChar(30)
  passportNumber       String?   @map("passport_number") @db.VarChar(50)
  nationalityCountryId String?   @map("nationality_country_id") @db.Uuid
  dateOfBirth          DateTime? @map("date_of_birth") @db.Date
  addressLine1         String?   @map("address_line1") @db.VarChar(255)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz

  agency   Agency    @relation(fields: [tenantId], references: [id])
  bookings Booking[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@map("customers")
}

// Global reference data (MASTER.md §4, DATABASE.md §3.6): no tenant_id, no deletedAt —
// seeded once by the platform, shared read-only across every Agency, retired via isActive.
model Country {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  isoCode   String   @unique @map("iso_code") @db.Char(2)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  cities City[]

  @@index([name])
  @@map("countries")
}

model City {
  id        String   @id @default(uuid()) @db.Uuid
  countryId String   @map("country_id") @db.Uuid
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  country Country @relation(fields: [countryId], references: [id])
  airports Airport[]

  @@unique([countryId, name])
  @@index([countryId])
  @@index([name])
  @@map("cities")
}

model Airport {
  id        String   @id @default(uuid()) @db.Uuid
  cityId    String   @map("city_id") @db.Uuid
  iataCode  String   @unique @map("iata_code") @db.Char(3)
  icaoCode  String?  @map("icao_code") @db.Char(4)
  name      String   @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  city City @relation(fields: [cityId], references: [id])
  sectorsAsOrigin      Sector[] @relation("SectorOriginAirport")
  sectorsAsDestination Sector[] @relation("SectorDestinationAirport")

  @@index([cityId])
  @@index([icaoCode])
  @@map("airports")
}

model Airline {
  id        String   @id @default(uuid()) @db.Uuid
  iataCode  String   @unique @map("iata_code") @db.Char(2)
  icaoCode  String?  @map("icao_code") @db.Char(3)
  name      String   @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  sectors Sector[]

  @@index([name])
  @@map("airlines")
}

// Status column only in this task (TASKS.md T28) — the Workflow Engine (T36-T39) becomes
// the sole mutator of this field later; no transition logic exists yet.
enum BookingStatus {
  draft
  reserved
  ticket_issued
  invoiced
  paid
  completed
  refunded
  cancelled

  @@map("booking_status")
}

model Booking {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @map("tenant_id") @db.Uuid
  bookingReference String        @map("booking_reference") @db.VarChar(30)
  customerId       String        @map("customer_id") @db.Uuid
  branchId         String        @map("branch_id") @db.Uuid
  agentId          String        @map("agent_id") @db.Uuid
  status           BookingStatus @default(draft)
  currencyCode     String        @map("currency_code") @db.Char(3)
  totalAmount      Decimal       @default(0.00) @map("total_amount") @db.Decimal(12, 2)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?     @map("deleted_at") @db.Timestamptz

  agency     Agency      @relation(fields: [tenantId], references: [id])
  customer   Customer    @relation(fields: [customerId], references: [id])
  branch     Branch      @relation(fields: [branchId], references: [id])
  agent      User        @relation(fields: [agentId], references: [id])
  passengers Passenger[]
  sectors    Sector[]

  @@unique([tenantId, bookingReference])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, createdAt])
  @@map("bookings")
}

// No tenant_id column directly (DATABASE.md §3.8) — always reached through booking_id;
// tenant scoping comes from verifying the parent Booking first (CODING_STANDARDS §4:
// BookingRepository owns Passenger/Sector/Fare/Tax/Ticket/Remarks as one aggregate).
enum PassengerType {
  ADT
  CHD
  INF

  @@map("passenger_type")
}

model Passenger {
  id                   String        @id @default(uuid()) @db.Uuid
  bookingId            String        @map("booking_id") @db.Uuid
  firstName            String        @map("first_name") @db.VarChar(100)
  lastName             String        @map("last_name") @db.VarChar(100)
  dateOfBirth          DateTime?     @map("date_of_birth") @db.Date
  passportNumber       String?       @map("passport_number") @db.VarChar(50)
  passengerType        PassengerType @default(ADT) @map("passenger_type")
  nationalityCountryId String?       @map("nationality_country_id") @db.Uuid
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@map("passengers")
}

enum CabinClass {
  economy
  premium_economy
  business
  first

  @@map("cabin_class")
}

model Sector {
  id                   String     @id @default(uuid()) @db.Uuid
  bookingId            String     @map("booking_id") @db.Uuid
  airlineId            String     @map("airline_id") @db.Uuid
  originAirportId      String     @map("origin_airport_id") @db.Uuid
  destinationAirportId String     @map("destination_airport_id") @db.Uuid
  flightNumber         String     @map("flight_number") @db.VarChar(10)
  cabinClass           CabinClass @default(economy) @map("cabin_class")
  departureAt          DateTime   @map("departure_at") @db.Timestamptz
  arrivalAt            DateTime   @map("arrival_at") @db.Timestamptz
  sequenceNumber       Int        @default(1) @map("sequence_number") @db.SmallInt
  createdAt            DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  booking            Booking @relation(fields: [bookingId], references: [id])
  airline            Airline @relation(fields: [airlineId], references: [id])
  originAirport      Airport @relation("SectorOriginAirport", fields: [originAirportId], references: [id])
  destinationAirport Airport @relation("SectorDestinationAirport", fields: [destinationAirportId], references: [id])

  @@index([bookingId])
  @@index([airlineId])
  @@index([originAirportId])
  @@index([destinationAirportId])
  @@map("sectors")
}
