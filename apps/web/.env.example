# Copy this file to .env.local for local development.
# See docs/ENVIRONMENT_VARIABLES.md for the full reference.

# Optional. Origin of the API the browser calls. Defaults to http://localhost:3001 if
# unset. This is a build-time value (inlined into the client bundle) — changing it
# requires a rebuild, not just a container restart. When building the Docker image,
# pass it as --build-arg NEXT_PUBLIC_API_URL=... instead of setting it at runtime.
NEXT_PUBLIC_API_URL=http://localhost:3001
